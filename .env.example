# Production API base for the frontend build
# Use same-origin when frontend and backend are served from one Node app:
# VITE_API_URL=/api

# If frontend is hosted separately, set full backend URL, for example:
# VITE_API_URL=https://api.seagreen-goldfish-450668.hostingersite.com/api
VITE_API_URL=/api

# Optional: local dev override for Vite proxy target
VITE_DEV_API_TARGET=http://localhost:4000
